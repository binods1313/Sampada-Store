# =============================================================================
# SAMPADA E-COMMERCE - ENVIRONMENT VARIABLES
# =============================================================================
# Copy this file to .env.local and fill in your values
# =============================================================================

# =============================================================================
# EXISTING STORE CONFIGURATION (Keep your existing values)
# =============================================================================

# Sanity CMS
NEXT_PUBLIC_SANITY_PROJECT_ID=your_sanity_project_id
SANITY_API_TOKEN=your_sanity_api_token

# Stripe (Main Store)
NEXT_PUBLIC_STRIPE_KEY=pk_live_or_test_xxx
STRIPE_SECRET_KEY=sk_live_or_test_xxx

# Printify Integration
PRINTIFY_API_KEY=your_printify_api_key
PRINTIFY_SHOP_ID=your_printify_shop_id

# NextAuth
NEXTAUTH_SECRET=generate_with_openssl_rand_base64_32
NEXTAUTH_URL=http://localhost:3000

# OAuth Providers (Required for Login)
GITHUB_ID=your_github_client_id
GITHUB_SECRET=your_github_client_secret
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# =============================================================================
# NEW: DESIGNER FEATURE - DATABASE
# =============================================================================

# PostgreSQL Database (Required for Designer Feature)
# 
# Option 1: Local PostgreSQL
# DATABASE_URL="postgresql://postgres:password@localhost:5432/sampada"
#
# Option 2: Google Cloud SQL (Production)
# DATABASE_URL="postgresql://sampada-user:YOUR_PASSWORD@CLOUD_SQL_IP:5432/sampada"
#
# Option 3: Supabase (Alternative)
# DATABASE_URL="postgresql://postgres:password@db.xxxx.supabase.co:5432/postgres"

DATABASE_URL="postgresql://username:password@host:5432/database_name"

# =============================================================================
# NEW: DESIGNER FEATURE - GOOGLE CLOUD
# =============================================================================

# Google Cloud Project
GOOGLE_CLOUD_PROJECT_ID=sampada-store-87848430

# Google Cloud Storage (for design thumbnails)
GCS_BUCKET_NAME=sampada-storage-87848430

# Service Account Key (path to your JSON key file)
# Download from Google Cloud Console > IAM > Service Accounts > Keys
GCS_KEY_FILE=./gcs-key.json

# =============================================================================
# NEW: DESIGNER FEATURE - STRIPE SUBSCRIPTIONS
# =============================================================================
# Create these products in your Stripe Dashboard:
# - Product 1: "Sampada Designer Pro" - $30/month
# - Product 2: "Sampada Designer Ultra" - $300/month
# Then copy the Price IDs here

# Designer-specific Stripe keys (can be same as main store)
NEXT_PUBLIC_STRIPE_DESIGNER_KEY=pk_live_or_test_xxx
STRIPE_DESIGNER_SECRET=sk_live_or_test_xxx

# Stripe Price IDs for Designer subscriptions
STRIPE_DESIGNER_PRO_PRICE_ID=price_xxx_pro
STRIPE_DESIGNER_ULTRA_PRICE_ID=price_xxx_ultra

# Stripe Webhook Secret for Designer
# Get this when you create webhook endpoint: /api/subscriptions/designer/webhook
STRIPE_DESIGNER_WEBHOOK_SECRET=whsec_xxx

# =============================================================================
# NEW: AI FEATURES (Optional - for Ultra tier)
# =============================================================================

# Google AI (Gemini) for design suggestions
GOOGLE_AI_API_KEY=your_google_ai_api_key

# =============================================================================
# DEBUGGING (Optional)
# =============================================================================

# Enable NextAuth debugging
# DEBUG=true
