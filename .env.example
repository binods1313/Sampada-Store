# ===== SAMPADA ENVIRONMENT CONFIGURATION =====
# Copy this file to .env.local for development or .env.production for production
# Never commit .env files to git!

# ==================== DATABASE ====================

# Cloud SQL PostgreSQL (Production)
# Format: postgresql://user:password@host:port/database?sslmode=require
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@10.15.32.2:5432/sampada?sslmode=require"

# For Cloud Run with Cloud SQL Auth Proxy:
# DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@/sampada?host=/cloudsql/PROJECT:REGION:INSTANCE"

# Local Development (Optional)
# DATABASE_URL="postgresql://postgres@127.0.0.1:5432/postgres?schema=public"

# ==================== STRIPE (Designer Subscriptions) ====================

# Test Mode (Live Account) - Current Setup
# Account: Binod Tech Ventures (acct_1RHrXyBwS3cUKJNr)
# Get your keys from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="sk_test_YOUR_STRIPE_SECRET_KEY"
NEXT_PUBLIC_STRIPE_DESIGNER_KEY="pk_test_YOUR_STRIPE_PUBLISHABLE_KEY"

# Subscription Price IDs (Create in Stripe Dashboard)
# Go to: https://dashboard.stripe.com/products
STRIPE_DESIGNER_PRO_PRICE_ID="price_YOUR_PRO_PRICE_ID"
STRIPE_DESIGNER_ULTRA_PRICE_ID="price_YOUR_ULTRA_PRICE_ID"

# Webhook Secret
# Create webhook at: https://dashboard.stripe.com/webhooks
# Endpoint: /api/subscriptions/designer/webhook
STRIPE_WEBHOOK_SECRET="whsec_YOUR_WEBHOOK_SECRET"

# Production Mode (After Business Verification)
# Get from: https://dashboard.stripe.com/apikeys
# STRIPE_SECRET_KEY="sk_live_..."
# NEXT_PUBLIC_STRIPE_DESIGNER_KEY="pk_live_..."
# STRIPE_DESIGNER_PRO_PRICE_ID="price_..." (create in live dashboard)
# STRIPE_DESIGNER_ULTRA_PRICE_ID="price_..." (create in live dashboard)
# STRIPE_WEBHOOK_SECRET="whsec_..." (create live webhook)

# ==================== GOOGLE CLOUD ====================

# Project Configuration
GOOGLE_CLOUD_PROJECT_ID="sampada-store-2026"
GCS_BUCKET_NAME="sampada-storage-87848430"

# Service Account (for Cloud Run)
# GOOGLE_APPLICATION_CREDENTIALS="/app/service-account.json"

# ==================== GOOGLE AI (Gemini) ====================

# Get from: https://makersuite.google.com/app/apikey
GOOGLE_AI_API_KEY="AIzaSy..."

# ==================== OPENROUTER (AI Integration) ====================

# Get from: https://openrouter.ai/keys
# You can configure multiple keys for rotation and reliability
OPENROUTER_API_KEY="sk-or-v1-YOUR_OPENROUTER_API_KEY"

# Optional: Additional keys for rotation (uncomment to use)
# OPENROUTER_API_KEY_2="sk-or-v1-YOUR_SECOND_KEY"
# OPENROUTER_API_KEY_3="sk-or-v1-YOUR_THIRD_KEY"

# Default model (optional - uses free NVIDIA Nemotron by default)
# OPENROUTER_DEFAULT_MODEL="google/gemma-3-12b-it:free"

# ==================== SENDGRID (Email Notifications) ====================

# Get from: https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY="SG...."
SENDGRID_FROM_EMAIL="noreply@your-domain.com"
SENDGRID_FROM_NAME="Sampada"

# ==================== PRINTIFY (Fulfillment) ====================

# Get from: https://printify.com/app/settings/api
PRINTIFY_API_KEY="..."

# Get from: https://printify.com/app/stores
PRINTIFY_SHOP_ID="..."

# ==================== APPLICATION ====================

# Environment
NODE_ENV="production"

# Base URLs
NEXT_PUBLIC_BASE_URL="https://sampada-xoa6kn2lwa-uc.a.run.app"
NEXT_PUBLIC_API_URL="https://sampada-xoa6kn2lwa-uc.a.run.app"

# For custom domain (after configuration):
# NEXT_PUBLIC_BASE_URL="https://your-domain.com"
# NEXT_PUBLIC_API_URL="https://your-domain.com"

