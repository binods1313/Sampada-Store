# ===== SAMPLE ENVIRONMENT FILE FOR PRODUCTION =====
# Copy this file to .env.production and fill in your actual values

# ===== DATABASE (Cloud SQL PostgreSQL) =====
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@PRIVATE_IP:5432/sampada?sslmode=disable"

# ===== STRIPE (Designer Subscriptions - PRODUCTION MODE) =====
# Get your live keys from: https://dashboard.stripe.com/apikeys
STRIPE_DESIGNER_SECRET=sk_live_...  # Replace with your actual live secret key
NEXT_PUBLIC_STRIPE_DESIGNER_KEY=pk_live_...  # Replace with your actual live publishable key

# Create these products in Stripe Dashboard: https://dashboard.stripe.com/products
# 1. "Sampada Pro" - $30/month → Copy the Price ID below
# 2. "Sampada Ultra" - $300/month → Copy the Price ID below
STRIPE_DESIGNER_PRO_PRICE_ID=price_...  # Replace with Pro price ID
STRIPE_DESIGNER_ULTRA_PRICE_ID=price_...  # Replace with Ultra price ID

# Create webhook endpoint: https://dashboard.stripe.com/webhooks
# Endpoint URL: https://your-domain.com/api/subscriptions/designer/webhook
# Events: customer.subscription.created, customer.subscription.updated, customer.subscription.deleted
STRIPE_DESIGNER_WEBHOOK_SECRET=whsec_...  # Replace with webhook signing secret

# ===== GOOGLE CLOUD =====
GOOGLE_CLOUD_PROJECT_ID="sampada-store-87848430"
GS_BUCKET_NAME="sampada-storage-87848430"
GOOGLE_APPLICATION_CREDENTIALS="/app/service-account.json"

# ===== GOOGLE AI (Gemini) =====
GOOGLE_AI_API_KEY="AIzaSy..."  # Get from: https://makersuite.google.com/app/apikey

# ===== SENDGRID (Email Notifications) =====
SENDGRID_API_KEY="SG...."  # Get from: https://app.sendgrid.com/settings/api_keys
SENDGRID_FROM_EMAIL="noreply@your-domain.com"
SENDGRID_FROM_NAME="Sampada"

# ===== PRINTIFY (Fulfillment) =====
PRINTIFY_API_KEY="..."  # Get from: https://printify.com/app/settings/api
PRINTIFY_SHOP_ID="..."  # Get from: https://printify.com/app/stores

# ===== APPLICATION =====
NODE_ENV="production"
NEXT_PUBLIC_BASE_URL="https://your-domain.com"  # Replace with your actual domain
NEXT_PUBLIC_API_URL="https://your-domain.com"

# ===== OPTIONAL: SHIPPING RATES =====
STRIPE_SHIPPING_RATE_STANDARD="shr_..."  # Create in Stripe Dashboard
STRIPE_SHIPPING_RATE_EXPRESS="shr_..."  # Create in Stripe Dashboard
