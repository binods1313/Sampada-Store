# ===== DATABASE CONFIGURATION =====

# ===== LOCAL DEVELOPMENT =====
# Default local PostgreSQL connection
DATABASE_URL="postgresql://postgres@127.0.0.1:5432/postgres?schema=public"

# ===== CLOUD SQL (PRODUCTION) =====
# Option A: Cloud SQL Auth Proxy (Recommended for Cloud Run)
# Format: postgresql://user:password@/database?host=/cloudsql/project:region:instance
CLOUD_SQL_DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@/sampada?host=/cloudsql/sampada-store-87848430:us-central1:sampada-production"

# Option B: Private IP Connection
# Format: postgresql://user:password@private-ip:5432/database
# CLOUD_SQL_DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@PRIVATE_IP:5432/sampada?sslmode=disable"

# ===== PRODUCTION DATABASE_URL =====
# This is what the application uses
# For Cloud Run deployment, set this to the Cloud SQL connection string
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@/sampada?host=/cloudsql/sampada-store-87848430:us-central1:sampada-production"

# ===== DATABASE CONNECTION POOLING =====
# For high-traffic production, you may want to configure a connection pooler
# Options: PgBouncer, Cloud SQL Proxy with connection pooling
# DATABASE_POOLER_URL="postgresql://postgres:password@pooler-host:6432/sampada"

# ===== PRISMA CONFIGURATION =====
# Direct URL for migrations (optional - for production setups with separate migration DB)
# DIRECT_URL="postgresql://postgres:password@direct-connection:5432/sampada"
