# Sanity Environment Variables
# Copy this file to .env and fill in your values

# Sanity Project Configuration
SANITY_PROJECT_ID=7lh35oho
SANITY_DATASET=production
SANITY_API_VERSION=2024-05-18

# Sanity API Token (Required for migration scripts)
# Generate at: https://www.sanity.io/manage/personal/project/7lh35oho/api
# Create a token with "write" permissions
SANITY_API_TOKEN=your_personal_api_token_here

# Optional: Auto-confirm migrations (use with caution)
AUTO_CONFIRM=false

# ============================================
# Google Analytics Dashboard
# ============================================
# Required for sanity-plugin-google-analytics
# Service Account: sanity-analytics-reader
# Project: sampada-store-2026
# Created: April 12, 2026

GA_CLIENT_EMAIL=sanity-analytics-reader@sampada-store-2026.iam.gserviceaccount.com
GA_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nREPLACE_WITH_ACTUAL_KEY_FROM_DOWNLOADED_JSON_FILE\n-----END PRIVATE KEY-----\n"
GA_VIEW_ID=REPLACE_WITH_YOUR_GA_VIEW_ID

# ⚠️ IMPORTANT: 
# - Get GA_PRIVATE_KEY from: sampada-store-2026-bb700bb6e7ed.json (downloaded file)
# - Get GA_VIEW_ID from: Google Analytics → Admin → View Settings → View ID
# - Never commit the .env file or JSON key file to Git!

# Optional: AI Assist Configuration (Optional)
# If using OpenRouter or other AI providers with Sanity Assist
# OPENROUTER_API_KEY=your_openrouter_api_key_here

# ============================================
# Slack Publisher (Coming Soon - Package Not Published)
# ============================================
# The sanity-plugin-slack-publisher is listed on Sanity.io
# but not yet published to npm. Will be added when available.
# 
# For now, use manual publishing or Sanity Content Agent (official):
# https://www.sanity.io/blog/content-agent-meet-slack
#
# SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# ============================================
# Skynet Accessibility Scanner
# ============================================
# Required for sanity-plugin-skynetaccessibility-scanner
# Scans your website for WCAG compliance and accessibility issues

NEXT_PUBLIC_BASE_URL=http://localhost:3000
# For production: https://your-sampada-store.com

# Optional: Email for accessibility reports
# ACCESSIBILITY_REPORT_EMAIL=admin@sampada.com
