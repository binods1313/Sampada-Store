// This file was auto generated by 'prisma init' and now customized

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ============ DESIGNER USER MODEL ============
model DesignUser {
  id                    String    @id @default(cuid())
  email                 String    @unique
  name                  String?
  
  // Designer subscription (SEPARATE from store purchases)
  designerTier          String    @default("free") // 'free' | 'pro' | 'ultra'
  stripeDesignerId      String?   @unique // Different from store Stripe customer
  designerSubStatus     String?   // 'active' | 'canceled' | 'past_due'
  designerPeriodEnd     DateTime?
  
  // Usage quotas
  designsCreatedThisMonth Int     @default(0)
  designLimit           Int?      // 2 (free), 50 (pro), null (ultra)
  
  // Feature flags
  features              Json      @default("{\"aiAssistant\": false, \"aiImageGen\": false, \"multiProductPreview\": false, \"customBranding\": false}")
  
  // Relations
  customDesigns         CustomDesign[]
  customOrders          CustomOrder[]
  
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([email])
  @@index([designerTier])
}

// ============ CUSTOM DESIGN MODEL ============
model CustomDesign {
  id                    String    @id @default(cuid())
  userId                String
  user                  DesignUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  name                  String
  description           String?
  
  // Canvas data (Fabric.js JSON)
  canvasData            Json
  thumbnail             String?   // GCS URL: gs://bucket/thumbnails/...
  
  // Printify integration
  printifyProductId     String?
  printifyProductUrl    String?
  
  // Status
  status                String    @default("draft") // 'draft' | 'processing' | 'live' | 'archived'
  tier                  String    // Which tier user had when design was created
  version               Int       @default(1)
  
  // AI tracking
  aiGeneratedElements   Json[]    @default([]) // [{type: 'suggestion', model: 'gemini', timestamp}]
  
  // Sharing
  isPublic              Boolean   @default(false)
  shareToken            String?   @unique
  
  // Relations
  customOrders          CustomOrder[]
  
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@index([isPublic])
}

// ============ CUSTOM ORDER MODEL ============
model CustomOrder {
  id                    String    @id @default(cuid())
  userId                String
  user                  DesignUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  customDesignId        String
  design                CustomDesign @relation(fields: [customDesignId], references: [id], onDelete: Restrict)
  
  // STUDIO_FINAL: Bridge to Sanity products
  sanityProductId       String?   // Links to Sanity product._id
  
  // Printify order tracking
  printifyOrderId       String?   @unique
  status                String    @default("pending") // 'pending' | 'production' | 'shipped' | 'delivered' | 'failed'
  paymentStatus         String    @default("pending") // 'pending' | 'completed' | 'failed' | 'refunded'
  trackingNumber        String?
  
  // Shipping information
  customerEmail         String
  customerName          String
  shippingAddress       Json      // {firstName, lastName, email, phone, country, state, city, address, zip}
  
  // Order details
  variantId             String    // Size/color from Printify
  quantity              Int       @default(1)
  priceInCents          Int       // e.g., 3000 = $30.00
  totalAmount           Float?    // Total order amount in dollars
  
  // Stripe payment
  stripePaymentIntentId String?
  
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@index([customDesignId])
  @@index([sanityProductId])
  @@index([printifyOrderId])
  @@index([status])
  @@index([paymentStatus])
}

// ============ DESIGN TEMPLATES MODEL ============
model DesignTemplate {
  id                    String    @id @default(cuid())
  name                  String
  description           String?
  category              String    // 'minimal' | 'bohemian' | 'sports' | 'seasonal'
  
  // Canvas template
  canvasData            Json
  thumbnail             String?   // GCS URL
  
  // Metadata
  isPublic              Boolean   @default(false)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([category])
  @@index([isPublic])
}

// ============ USAGE LOGS MODEL ============
model DesignUsageLog {
  id                    String    @id @default(cuid())
  userId                String
  action                String    // 'design_created' | 'ai_used' | 'export' | 'order_placed'
  tier                  String    // 'free' | 'pro' | 'ultra'
  metadata              Json?     // Extra data
  timestamp             DateTime  @default(now())

  @@index([userId])
  @@index([action])
  @@index([timestamp])
}

// ============ STUDIO_FINAL: INTEGRATION MODELS ============

// Product cache for fast Sanity product lookups
model ProductCache {
  id                    String    @id @default(cuid())
  sanityId              String    @unique  // Sanity product._id
  name                  String
  price                 Float
  inStock               Boolean
  
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([sanityId])
  @@index([inStock])
}

// Search log for AI dynamic collections
model SearchLog {
  id                    String    @id @default(cuid())
  query                 String
  userId                String?
  resultsCount          Int?      // Number of results returned
  
  createdAt             DateTime  @default(now())

  @@index([userId])
  @@index([createdAt])
}

// Personalized content cache
model PersonalizedContent {
  id                    String    @id @default(cuid())
  userId                String
  productId             String    // Sanity product._id
  tagline               String
  
  generatedAt           DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@unique([userId, productId])
  @@index([userId])
  @@index([productId])
  @@index([generatedAt])
}
