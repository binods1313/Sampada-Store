# .gitignore
# ===========

# Environment Variables
.env*.local
.env.development
.env.production
.env.test
.env
# Backup files from domain migration script
.env*.backup-*

# Secret key files — NEVER commit these
gcs-service-account.json
*.service-account.json
*-service-account.json

# Claude local settings (contains API keys)
.claude/

# Dependency Directories
node_modules/
/.pnp
.pnp.js
.yarn-integrity
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz

# Build Artifacts
/.next/
/out/
/dist/
/build/
.sanity/

# Log Files
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# System Files
.DS_Store
Thumbs.db
*.swp
*.swo

# Editor/IDE
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Security
*.pem
*.key
*.cert
*.crt
*.pgp

# Sanity Studio Specific
.sanity/
sanity.json
static/admin/

# Test Coverage
/coverage/
.nyc_output/

# Optional
.cache/
.tmp/
temp/"notebooklm-py/"  
"ui-ux-pro-max-skill/"  
"ui/"  
"magic-mcp/"  
"hoppscotch/"  
config/admin-auth.json 

.vercel

# Documentation (internal/sensitive)
docs/DOMAIN_MIGRATION_GUIDE.md
docs/DOMAIN_MIGRATION_QUICK_CHECKLIST.md
docs/DOMAIN_SETUP_SUMMARY.md
docs/WHAT_I_DID_DOMAIN_SETUP.md
DOMAIN_QUICKSTART.md
